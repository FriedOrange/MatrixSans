@shortcurveL_gr = [alphatonos epsilontonos alpha epsilon omicron sigmafinal sigma omegatonos omega phi1 zero.sc uni03D9 uni03DB uni03F5];
@shortcurveTL_gr = [rho omega.sc omegatonos.sc uni03F1];
