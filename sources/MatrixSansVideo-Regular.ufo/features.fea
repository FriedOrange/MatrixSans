feature mark {
	pos base @tall
		<anchor 300 800> mark @marks_above
		<anchor 550 500> mark @marks_aboveright
		<anchor 300 0> mark @marks_below
		<anchor 300 0> mark @marks_belowright;
	pos base @tall_ogonek
		<anchor 300 800> mark @marks_above
		<anchor 550 500> mark @marks_aboveright
		<anchor 300 0> mark @marks_below
		<anchor 400 0> mark @marks_belowright;
	pos base @tall_narrow
		<anchor 200 800> mark @marks_above
		<anchor 250 500> mark @marks_aboveright
		<anchor 200 0> mark @marks_below
		<anchor 200 0> mark @marks_belowright;
	pos base @tall_1wide
		<anchor 100 800> mark @marks_above
		<anchor 150 500> mark @marks_aboveright
		<anchor 100 0> mark @marks_below
		<anchor 100 0> mark @marks_belowright;
	pos base @tall_4wide
		<anchor 200 800> mark @marks_above
		<anchor 450 500> mark @marks_aboveright
		<anchor 200 0> mark @marks_below
		<anchor 300 0> mark @marks_belowright;
	pos base @tall_6wide
		<anchor 400 800> mark @marks_above
		<anchor 650 500> mark @marks_aboveright
		<anchor 400 0> mark @marks_below
		<anchor 500 0> mark @marks_belowright;
	pos base @tall_6wide2
		<anchor 300 800> mark @marks_above
		<anchor 650 500> mark @marks_aboveright
		<anchor 300 0> mark @marks_below
		<anchor 400 0> mark @marks_belowright;
	pos base @tall_7wide
		<anchor 400 800> mark @marks_above
		<anchor 750 500> mark @marks_aboveright
		<anchor 400 0> mark @marks_below
		<anchor 500 0> mark @marks_belowright;
	pos base @verytall
		<anchor 300 1000> mark @marks_above
		<anchor 550 500> mark @marks_aboveright
		<anchor 300 0> mark @marks_below
		<anchor 300 0> mark @marks_belowright;
	pos base @verytall_narrow
		<anchor 200 1000> mark @marks_above
		<anchor 250 500> mark @marks_aboveright
		<anchor 200 0> mark @marks_below
		<anchor 200 0> mark @marks_belowright;
	pos base @verytall_7wide
		<anchor 400 1000> mark @marks_above
		<anchor 750 500> mark @marks_aboveright
		<anchor 400 0> mark @marks_below
		<anchor 500 0> mark @marks_belowright;
	pos base @long
		<anchor 300 800> mark @marks_above
		<anchor 550 500> mark @marks_aboveright
		<anchor 300 -200> mark @marks_below
		<anchor 400 -200> mark @marks_belowright;
	pos base @long_narrow
		<anchor 200 800> mark @marks_above
		<anchor 250 500> mark @marks_aboveright
		<anchor 200 -200> mark @marks_below
		<anchor 200 -200> mark @marks_belowright;
	pos base @long_7wide
		<anchor 400 800> mark @marks_above
		<anchor 750 500> mark @marks_aboveright
		<anchor 400 -200> mark @marks_below
		<anchor 500 -200> mark @marks_belowright;
	pos base @verylong
		<anchor 300 1000> mark @marks_above
		<anchor 550 500> mark @marks_aboveright
		<anchor 300 -200> mark @marks_below
		<anchor 400 -200> mark @marks_belowright;
	pos base @verylong_narrow
		<anchor 200 1000> mark @marks_above
		<anchor 250 500> mark @marks_aboveright
		<anchor 200 -200> mark @marks_below
		<anchor 200 -200> mark @marks_belowright;
	pos base @J
		<anchor 400 800> mark @marks_above
		<anchor 550 500> mark @marks_aboveright
		<anchor 300 0> mark @marks_below
		<anchor 300 0> mark @marks_belowright;
	pos base @Jsc
		<anchor 400 600> mark @marks_above
		<anchor 550 300> mark @marks_aboveright
		<anchor 300 0> mark @marks_below
		<anchor 300 0> mark @marks_belowright;
	pos base @L
		<anchor 100 800> mark @marks_above
		<anchor 150 500> mark @marks_aboveright
		<anchor 300 0> mark @marks_below
		<anchor 300 0> mark @marks_belowright;
	pos base @Lsc
		<anchor 300 600> mark @marks_above
		<anchor 150 300> mark @marks_aboveright
		<anchor 300 0> mark @marks_below
		<anchor 300 0> mark @marks_belowright;
	pos base @short
		<anchor 300 600> mark @marks_above
		<anchor 550 300> mark @marks_aboveright
		<anchor 300 0> mark @marks_below
		<anchor 300 0> mark @marks_belowright;
	pos base @short_narrow
		<anchor 200 600> mark @marks_above
		<anchor 350 300> mark @marks_aboveright
		<anchor 200 0> mark @marks_below
		<anchor 200 0> mark @marks_belowright;
	pos base @short_ogonek
		<anchor 300 600> mark @marks_above
		<anchor 550 300> mark @marks_aboveright
		<anchor 300 0> mark @marks_below
		<anchor 400 0> mark @marks_belowright;
	pos base @short_4wide
		<anchor 200 600> mark @marks_above
		<anchor 450 300> mark @marks_aboveright
		<anchor 200 0> mark @marks_below
		<anchor 300 0> mark @marks_belowright;
	pos base @short_6wide
		<anchor 400 600> mark @marks_above
		<anchor 650 300> mark @marks_aboveright
		<anchor 400 0> mark @marks_below
		<anchor 400 0> mark @marks_belowright;
	pos base @short_6wide2
		<anchor 300 600> mark @marks_above
		<anchor 650 300> mark @marks_aboveright
		<anchor 300 0> mark @marks_below
		<anchor 300 0> mark @marks_belowright;
	pos base @short_7wide
		<anchor 400 600> mark @marks_above
		<anchor 750 300> mark @marks_aboveright
		<anchor 400 0> mark @marks_below
		<anchor 400 0> mark @marks_belowright;
	pos base @deep
		<anchor 300 600> mark @marks_above
		<anchor 550 300> mark @marks_aboveright
		<anchor 300 -200> mark @marks_below
		<anchor 300 -200> mark @marks_belowright;
	pos base @deep_narrow
		<anchor 200 600> mark @marks_above
		<anchor 350 300> mark @marks_aboveright
		<anchor 200 -200> mark @marks_below
		<anchor 200 -200> mark @marks_belowright;
	pos base @deep_7wide
		<anchor 400 600> mark @marks_above
		<anchor 750 300> mark @marks_aboveright
		<anchor 400 -200> mark @marks_below
		<anchor 400 -200> mark @marks_belowright;
	pos base @j_mark
		<anchor 400 800> mark @marks_above
		<anchor 450 500> mark @marks_aboveright
		<anchor 300 -200> mark @marks_below
		<anchor 300 -200> mark @marks_belowright;
	pos base @j_mark2
		<anchor 400 600> mark @marks_above
		<anchor 450 500> mark @marks_aboveright
		<anchor 300 -200> mark @marks_below
		<anchor 300 -200> mark @marks_belowright;
	pos base @t_mark
		<anchor 300 800> mark @marks_above
		<anchor 350 600> mark @marks_aboveright
		<anchor 300 0> mark @marks_below
		<anchor 300 0> mark @marks_belowright;
	pos mark @marks_above
		<anchor 0 800> mark @marks_above;
	pos mark @marks_below
		<anchor 0 -200> mark @marks_below;
} mark;

feature locl {
	script latn;
	language CAT;
		lookup locl_CAT {
			pos l periodcentered' <-100 0 -200 0> l;
			pos L periodcentered' <-300 0 -200 0> L;
			pos l.sc periodcentered' <-300 0 -200 0> l.sc;
		} locl_CAT;
	language TAT;
		sub i by idotaccent;
	language TRK;
		sub i by idotaccent;
	language KAZ;
		sub i by idotaccent;
	language AZE;
		sub i by idotaccent;
	language CRT;
		sub i by idotaccent;
	language MOL;
		sub Scedilla by Scommaaccent;
		sub scedilla by scommaaccent;
		sub Tcedilla by Tcommaaccent;
		sub tcedilla by tcommaaccent;
	language ROM;
		sub Scedilla by Scommaaccent;
		sub scedilla by scommaaccent;
		sub Tcedilla by Tcommaaccent;
		sub tcedilla by tcommaaccent;
	language NSM;
		lookup locl_NSM {
			sub Eng by Eng.loclNSM;
			sub eng.sc by eng.sc.loclNSM;
		} locl_NSM;		
	language NLD;
		sub iacute j by iacute_jacute;
		sub i acutecomb j by iacute_jacute;
		sub i j acutecomb by iacute_jacute;
		sub ij acutecomb by iacute_jacute;
		sub Iacute J by Iacute_Jacute;
		sub I acutecomb J by Iacute_Jacute;
		sub I acutecomb j by Iacute_Jacute;
		sub I acutecomb j.sc by Iacute_Jacute;
		sub I J acutecomb by Iacute_Jacute;
		sub I j acutecomb by Iacute_Jacute;
		sub I j.sc acutecomb by Iacute_Jacute;
		sub IJ acutecomb by Iacute_Jacute;
		sub i j by ij;
		sub i.sc j.sc by ij.sc;
		sub I [J j j.sc] by IJ;
	script cyrl;
		sub three by three.alt;
	language SRB;
		lookup locl_SRB {
			sub be-cy by be-cy.loclSRB;
		} locl_SRB;
	language BGR;
		lookup locl_BGR {
			sub [ve-cy ge-cy de-cy zhe-cy ze-cy ii-cy iishort-cy ka-cy el-cy pe-cy te-cy tse-cy sha-cy shcha-cy yu-cy] by [ve-cy.loclBGR ge-cy.loclBGR g zhe-cy.loclBGR ze-cy.loclBGR u ubreve k el-cy.loclBGR n m tse-cy.loclBGR ayb-ar shcha-cy.loclBGR yu-cy.loclBGR];
		} locl_BGR;
} locl;

