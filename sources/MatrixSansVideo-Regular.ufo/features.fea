@shortL_gr = [kappa mu upsilon phi psi upsilondieresis upsilontonos kaiSymbol guillemotright guilsinglright epsilontonos.sc etatonos.sc iotatonos.sc b.sc ge-cy e.sc z h.sc i.sc m.sc n.sc xi.sc pe-cy p.sc sigma.sc x uni03D6 uni03DD uni03F0 uni03F6 kgreenlandic];
