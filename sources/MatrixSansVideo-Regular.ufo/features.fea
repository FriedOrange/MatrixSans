feature tnum {
	pos one <100 0 200 0>;
} tnum;

feature zero {
	sub zero by O;
	sub zero.sc by o;
} zero;

@figures = [zero one two three four five six seven eight nine];
@figures_sc = [zero.sc one.sc two.sc three.sc four.sc five.sc six.sc seven.sc eight.sc nine.sc];
@numr = [uni2070 onesuperior twosuperior threesuperior foursuperior fivesuperior sixsuperior sevensuperior eightsuperior ninesuperior];
@dnom = [uni2080 oneinferior twoinferior threeinferior fourinferior fiveinferior sixinferior seveninferior eightinferior nineinferior];

lookup NUMR {
	sub @figures by @numr;
	sub @figures_sc by @numr;
} NUMR;

lookup DNOM {
	sub @figures by @dnom;
	sub @figures_sc by @dnom;
} DNOM;

feature numr {
	lookup NUMR;
} numr;

feature dnom {
	lookup DNOM;
} dnom;

feature frac {
	lookup NUMR;
	sub [slash fraction @dnom] @numr' by @dnom;
	sub [slash fraction] by NULL;
} frac;

feature sups {
	lookup NUMR;
} sups;

feature subs {
	lookup DNOM;
} subs;

feature ss01 {
	featureNames {
		name "Alternate capital letter D, etc.";
	};
	# these get added to the end of ccmp automatically for Video style
	sub D.alt by D;
	sub Eth.alt by Eth;
	sub Dcroat.alt by Dcroat;
	sub Dhook.alt by Dhook;
	sub Dcaron.alt by Dcaron;
	sub Ddotbelow.alt by Ddotbelow;
	sub Dmacronbelow.alt by Dmacronbelow;
} ss01;

feature ss02 {
	featureNames {
		name "Alternate numerals 2, 6 and 9";
	};
	sub two by two.alt;
	sub six by six.alt;
	sub nine by nine.alt;
} ss02;

feature ss03 {
	featureNames {
		name "Alternate numeral 3";
	};
	sub three by three.alt;
} ss03;

feature ss04 {
	featureNames {
		name "Alternate numeral 4";
	};
	sub four by four.alt;
} ss04;

feature ss05 {
	featureNames {
		name "Alternate small Greek letter φ (phi)";
	};
	sub phi by phi1;
	sub phi1 by phi;
} ss05;

feature ss06 {
	featureNames {
		name "Alternate capital letter Ŋ (Eng)";
	};
	lookup locl_NSM;
} ss06;

feature ss07 {
	featureNames {
		name "Serbian letter forms";
	};
	lookup locl_SRB;
} ss07;

feature ss08 {
	featureNames {
		name "Bulgarian letter forms";
	};
	lookup locl_BGR;
} ss08;

feature salt {
	sub two by two.alt;
	sub three by three.alt;
	sub four by four.alt;
	sub six by six.alt;
	sub nine by nine.alt;
	sub D by D.alt;
	sub Eth by Eth.alt;
	sub Dcaron by Dcaron.alt;
	sub Dcroat by Dcroat.alt;
	sub Dhook by Dhook.alt;
	sub Ddotbelow by Ddotbelow.alt;
	sub Dmacronbelow by Dmacronbelow.alt;
	sub Eng by Eng.loclNSM;
	sub eng.sc by eng.sc.loclNSM;
	sub phi by phi1;
	sub phi1 by phi;
	sub zero by O;
	sub zero.sc by o;
	lookup locl_SRB;
	lookup locl_BGR;
} salt;

feature dlig {
	# typically these would be in 'clig', but this is not a typical font
	sub f f i by f_f_i;
	sub f f l by f_f_l;
	sub f f by f_f;
	sub f i by f_i;
	sub f l by f_l;
} dlig;

feature case {
	pos questiondown <0 200 0 0>;
	pos exclamdown <0 200 0 0>;
	pos uni2E18 <0 200 0 0 >;
} case;
