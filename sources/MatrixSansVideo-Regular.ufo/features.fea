feature kern {
	script latn;
	# single pair kerning rules
	pos F j -300;
	pos F J -200;
	pos F Jcircumflex -200;
	pos P J -200;
	pos P Jcircumflex -200;
	pos P j.sc -200;
	pos P jcircumflex.sc -200;
	enum pos [g q y yacute eng eng.sc.loclNSM] @hookleft 100;
	enum pos [dcroat f] @aother -100;
	pos Chilatin s 0;

	# class kerning rules
	pos Chilatin @shortcurveTL -100;
	pos [comma quotesinglbase quotedblbase] @talloverhang3L -100;
	pos [comma quotesinglbase quotedblbase] @shortoverhangL -100;
	pos [j Eng.loclNSM] @hookleft 100;
	pos @talloverhangR @tallcurve2TL -100;
